<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_panel"
    android:clipToOutline="true"
    android:foreground="@drawable/bg_bottom_sheet_edge_shadow"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="12dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp">

        <View
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_group_share_handle" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/groupShareActionsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="2dp">

        <FrameLayout
            android:id="@+id/shareWechatAction"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/group_share_wechat"
                    android:scaleType="fitCenter"
                    android:src="@drawable/wechat_share_icon" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/shareDingTalkAction"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/group_share_dingtalk"
                    android:scaleType="fitCenter"
                    android:src="@drawable/dingtalk_share_icon" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/shareMoreAction"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_bottom_sheet_secondary_button">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/group_share_link_action"
                    android:padding="16dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_share_more"
                    android:tint="@color/zs_bottom_sheet_secondary_icon" />
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
