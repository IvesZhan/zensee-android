<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <FrameLayout
        android:layout_width="42dp"
        android:layout_height="42dp">

        <TextView
            android:id="@+id/groupManageMemberAvatarText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_group_member_avatar"
            android:gravity="center"
            android:textColor="@color/zs_primary_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/groupManageMemberAvatarImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_group_member_avatar"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/groupManageMemberNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/zs_primary_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/groupManageMemberStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/zs_text_subtle"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/groupManageMemberActionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_capsule_surface"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:textColor="@color/zs_text_subtle"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
