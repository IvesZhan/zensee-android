<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/groupPracticeSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_panel"
    android:clipToOutline="true"
    android:foreground="@drawable/bg_bottom_sheet_edge_shadow"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/groupPracticeTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        android:text="@string/group_practice_duration_title"
        android:textColor="@color/zs_primary_dark"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/groupPracticeDurationText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="@color/zs_primary_dark"
        android:textSize="36sp"
        android:textStyle="bold" />

    <com.zensee.android.widget.DialRulerView
        android:id="@+id/groupPracticeDurationDial"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="20dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/groupPracticeSaveButton"
            style="@style/Widget.ZenSee.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/save_action"
            android:textSize="17sp" />

        <ProgressBar
            android:id="@+id/groupPracticeSaveSpinner"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/zs_white"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
