<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/meditationRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zs_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <FrameLayout
        android:id="@+id/activeMeditationContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/activeTopContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="82dp">

            <TextView
                android:id="@+id/meditationPhaseText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.45"
                android:textColor="@color/zs_text_main"
                android:textSize="16sp" />

            <View
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="@color/zs_border" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/activeTimerCenter"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_gravity="center"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:id="@+id/timerRippleLarge"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@drawable/bg_ripple_ring" />

            <View
                android:id="@+id/timerRippleMedium"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@drawable/bg_ripple_ring_strong" />

            <View
                android:id="@+id/timerRippleSmall"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@drawable/bg_ripple_ring" />

            <TextView
                android:id="@+id/meditationTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-light"
                android:textColor="@color/zs_text_subtle"
                android:textSize="88sp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/activeBottomControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="64dp">

            <TextView
                android:id="@+id/resumeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_capsule_surface"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="40dp"
                android:paddingTop="12dp"
                android:paddingEnd="40dp"
                android:paddingBottom="12dp"
                android:text="@string/continue_meditation"
                android:textColor="@color/zs_text_subtle"
                android:textSize="14sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/endHoldProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="120dp"
                android:layout_height="3dp"
                android:layout_marginTop="16dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="@color/zs_ring_strong"
                android:progressTint="@color/zs_primary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/endHoldButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_capsule_outline"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingTop="10dp"
                android:paddingEnd="32dp"
                android:paddingBottom="10dp"
                android:text="@string/holding_end"
                android:textColor="@color/zs_text_subtle"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/completedMeditationContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/completedCenterCluster"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_gravity="center"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:translationY="-40dp">

            <View
                android:id="@+id/completedRippleLarge"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@drawable/bg_ripple_ring" />

            <View
                android:id="@+id/completedRippleMedium"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@drawable/bg_ripple_ring_strong" />

            <View
                android:id="@+id/completedRippleSmall"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@drawable/bg_ripple_ring" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/completedMinutesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:includeFontPadding="false"
                        android:textColor="@color/zs_gold"
                        android:textSize="52sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/completedMinutesUnitText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="serif"
                        android:text="@string/minutes_unit"
                        android:textColor="@color/zs_text_subtle"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:letterSpacing="0.3"
                    android:text="@string/meditation_total_duration"
                    android:textColor="@color/zs_text_subtle"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/completedBottomControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="56dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/recordMoodButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_capsule_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/record_mood"
                    android:textColor="@color/zs_primary"
                    android:textSize="16sp" />

                <Space
                    android:layout_width="16dp"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/shareButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_capsule_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/share"
                    android:textColor="@color/zs_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/returnHomeButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_primary_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/return_home"
                android:textColor="@color/zs_white"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
