<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/groupMoreMemberRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingTop="6dp"
    android:paddingEnd="4dp"
    android:paddingBottom="6dp">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp">

        <TextView
            android:id="@+id/groupMoreMemberAvatarText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_group_member_avatar"
            android:gravity="center"
            android:textColor="@color/zs_primary_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/groupMoreMemberAvatarImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_group_member_avatar"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/groupMoreMemberRemoveBadge"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_group_member_remove_badge"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone">

            <View
                android:id="@+id/groupMoreMemberRemoveLine"
                android:layout_width="8dp"
                android:layout_height="2dp"
                android:layout_gravity="center"
                android:background="@color/zs_white" />

            <ProgressBar
                android:id="@+id/groupMoreMemberRemoveProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="@color/zs_white"
                android:visibility="gone" />
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/groupMoreMemberNameText"
        android:layout_width="68dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:textColor="@color/zs_primary_dark"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
