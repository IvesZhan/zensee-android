<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/meditationSetupSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_panel"
    android:clipToOutline="true"
    android:foreground="@drawable/bg_bottom_sheet_edge_shadow"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="8dp">

    <FrameLayout
        android:id="@+id/setupContentContainer"
        android:layout_width="match_parent"
        android:layout_height="340dp">

        <LinearLayout
            android:id="@+id/mainSetupContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="20dp">

                <TextView
                    android:id="@+id/durationDisplayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="@color/zs_primary_dark"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/soundPickerButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_bottom_sheet_icon_button"
                    android:contentDescription="@string/meditation_sound"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_meditation_music"
                    android:tint="@color/zs_bottom_sheet_secondary_icon"
                    app:layout_constraintBottom_toBottomOf="@id/durationDisplayText"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/durationDisplayText" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/selectedSoundText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="@color/zs_text_subtle"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.zensee.android.widget.DialRulerView
                    android:id="@+id/durationDial"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/coolDownMenuButton"
                    android:layout_width="88dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_bottom_sheet_secondary_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="true"
                        android:text="@string/cool_down_short"
                        android:textColor="@color/zs_bottom_sheet_secondary_icon"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/coolDownValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="true"
                            android:textColor="@color/zs_primary_dark"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_bottom_sheet_chevron" />
                    </LinearLayout>
                </LinearLayout>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/confirmMeditationButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_button_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/start_now"
                    android:textColor="@color/zs_white"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/soundSelectionContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/soundBackButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_bottom_sheet_icon_button"
                    android:contentDescription="@string/meditation_sound_back"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_meditation_back"
                    android:tint="@color/zs_bottom_sheet_secondary_icon" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/soundRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="0dp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
