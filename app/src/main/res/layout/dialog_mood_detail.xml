<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup_card"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/moodDialogCloseButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="end"
        android:gravity="center"
        android:text="×"
        android:textColor="@color/zs_primary_dark"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/moodDialogLabelText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:letterSpacing="0.2"
        android:textColor="@color/zs_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/moodDialogDateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/zs_text_subtle"
        android:textSize="11sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fadeScrollbars="false"
        android:scrollbars="none">

        <TextView
            android:id="@+id/moodDialogContentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="10dp"
            android:textColor="@color/zs_text_main"
            android:textSize="15sp" />
    </ScrollView>

    <View
        android:layout_width="48dp"
        android:layout_height="1dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:background="@color/zs_border" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:letterSpacing="0.2"
        android:text="@string/meditation_duration_label"
        android:textColor="@color/zs_text_subtle"
        android:textSize="10sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/moodDialogDurationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/zs_primary"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"
            android:text="@string/minutes_unit"
            android:textColor="@color/zs_primary"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
