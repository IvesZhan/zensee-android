<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup_card"
    android:elevation="14dp"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/groupRecordDialogCloseButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="end"
        android:gravity="center"
        android:text="×"
        android:textColor="@color/zs_primary_dark"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/groupRecordDialogTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:letterSpacing="0.12"
        android:textColor="@color/zs_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/groupRecordDialogEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="@string/group_record_no_members"
        android:textColor="@color/zs_text_subtle"
        android:textSize="14sp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/groupRecordDialogScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:maxHeight="320dp"
        android:fadeScrollbars="false"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/groupRecordDialogMembersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
