<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/zs_capsule_button_ripple">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/zs_capsule_tint_fill" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1.5dp"
                android:color="@color/zs_primary" />
        </shape>
    </item>
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@color/zs_white" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</ripple>
