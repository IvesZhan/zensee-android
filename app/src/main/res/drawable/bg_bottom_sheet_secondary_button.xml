<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/zs_capsule_button_ripple">
    <item>
        <shape>
            <solid android:color="@color/zs_bottom_sheet_secondary_fill" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/zs_bottom_sheet_secondary_stroke" />
        </shape>
    </item>

    <item android:id="@android:id/mask">
        <shape>
            <solid android:color="@color/zs_bottom_sheet_secondary_fill" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</ripple>
